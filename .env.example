# === INFRAESTRUCTURA CORE ===
# Variables de control de FiftyOne database y persistencia.
FIFTYONE_DATABASE_DIR=~/.fiftyone/db
FIFTYONE_DATABASE_URI=mongodb://localhost:27017

# Nombre canónico del dataset que será compartido entre Módulos 01-06.
# Asegúrate de que esto coincida en toda la codebase (ingesta, API, Brain).
DATASET_NAME=hackathon-dataset

# === LLAMADAS E INFERENCIA DE AGENTES (VLMs) ===
# API keys para integración con proveedores de Vision Language Models.
OPENAI_API_KEY=tu_api_key_aquí
ANTHROPIC_API_KEY=tu_api_key_aquí

# === CAPA REST Y SERVIDORES ===
# Puertos para FastAPI (orquestación) y MCP Server (agentes externos).
FASTAPI_PORT=8000
MCP_SERVER_PORT=5152

# === PLUGINS DE FIFTYONE (MÓDULO 05) ===
# NOTA: Después de clonar el repo, ejecuta:
#   python setup_plugins.py
# Esto mapea automáticamente src/05_plugins/ → ~/.fiftyone/plugins/
# Los plugins aparecerán entonces en la App de FiftyOne (puerto 5151)